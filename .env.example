# ============================================================================
# HH Eval — example environment file.
#
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# This file documents the env-var NAMES the harness reads; it contains NO
# secrets. The model catalog (data/models/catalog.json) references these names
# only — never the values themselves.
# ============================================================================

# --- Foreign providers -------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Domestic (OpenAI-compatible) providers ---------------------------------
# Each domestic provider exposes an OpenAI-compatible endpoint; the harness
# swaps base_url + api_key per the model catalog.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# --- Backend / frontend ------------------------------------------------------
# Where the FastAPI backend serves from, and where the web app looks for it.
HH_EVAL_API_HOST=127.0.0.1
HH_EVAL_API_PORT=8000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# --- Harness data locations (override only if you move things) ---------------
# Defaults resolve relative to the repo root.
# HH_EVAL_TASKS_DIR=agentic_coding_samples
# HH_EVAL_RESULTS_DIR=results
